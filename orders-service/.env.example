# Orders Service Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# JWT_PUBLIC_KEY is auto-filled by:  node ../scripts/generate-keys.js
# ─────────────────────────────────────────────────────────────────
# NOTE: This service has NO database and NO Redis.
#       It validates JWTs using only the public key below.
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development          # change to: production  for prod

# ── JWT Public Key (RS256) ───────────────────────────────────────
# MUST be the same base64 value as JWT_PUBLIC_KEY in auth-service/.env
# Run:  node ../scripts/generate-keys.js  — it auto-fills this.
JWT_PUBLIC_KEY=

# ── Auth Service URL ─────────────────────────────────────────────
# Local manual:  http://localhost:3001
# Docker:        http://auth-service:3001
# Vercel:        https://your-auth-service.vercel.app
AUTH_SERVICE_URL=http://localhost:3001
