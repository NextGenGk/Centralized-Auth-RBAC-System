# Auth Service Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# Generate keys:   node ../scripts/generate-keys.js
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # change to: production  for prod

# ── Database (PostgreSQL) ────────────────────────────────────────
# Neon (cloud):  postgresql://USER:PASS@ep-xxx.aws.neon.tech/neondb?sslmode=require
# Local manual:  postgresql://postgres:postgres@localhost:5432/authdb
# Docker:        postgresql://postgres:postgres@postgres:5432/authdb
DATABASE_URL=

# ── Redis ────────────────────────────────────────────────────────
# Upstash (cloud): rediss://default:TOKEN@your-host.upstash.io:6380
# Local manual:    redis://localhost:6379
# Docker:          redis://redis:6379
REDIS_URL=

# ── JWT Keys (RS256 Asymmetric) ──────────────────────────────────
# Run:  node ../scripts/generate-keys.js
# This will auto-fill the two values below.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Security ─────────────────────────────────────────────────────
# 12 is production-safe (~300ms/hash). Use 10 for faster local dev.
BCRYPT_ROUNDS=12

# ── Rate Limiting ────────────────────────────────────────────────
LOGIN_RATE_LIMIT=10           # max login attempts per window
LOGIN_RATE_WINDOW=900         # window in seconds (15 min)
GLOBAL_RATE_LIMIT=100         # max requests per IP per window
GLOBAL_RATE_WINDOW=60         # window in seconds (1 min)
